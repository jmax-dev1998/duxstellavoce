rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── User Profiles ─────────────────────────────────────────────
    match /users/{userId} {

      // Create: only when registering yourself, with valid fields
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['name', 'email', 'avatar', 'role'])
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.email.matches('^[^@]+@[^@]+\\.[^@]+$')
        && request.resource.data.avatar is string
        && request.resource.data.role == 'guest';

      // Read your own profile
      allow read: if request.auth != null
        && request.auth.uid == userId;

      // Update your own profile (cannot change role, email, or uid)
      allow update: if request.auth != null
        && request.auth.uid == userId
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'email']))
        && request.resource.data.name is string
        && request.resource.data.avatar is string;

      // ── Admin: full access ──
      allow read, write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';

      // ── Manager: read-only ──
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager';
    }

    // ─── Members ──────────────────────────────────────────────────
    match /members/{memberId} {

      // Anyone can read
      allow read: if true;

      // Only admin & manager can write (create, update, delete)
      allow create: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager'];

      allow update: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager'];

      allow delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager'];
    }

    // ─── Events ────────────────────────────────────────────────────
    match /events/{eventId} {

      // Anyone can read
      allow read: if true;

      // Only admin & manager can write (create, update, delete)
      allow create: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager'];

      allow update: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager'];

      allow delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager'];
    }

    // ─── Library ──────────────────────────────────────────────────
    match /library/{pieceId} {

      // Anyone can read
      allow read: if true;

      // Only admin & manager can write (create, update, delete)
      allow create: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager'];

      allow update: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager'];

      allow delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager'];
    }

    // ─── Default: deny everything else ──────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
